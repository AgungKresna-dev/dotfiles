# ==========================================
# FONDASI UTAMA ZSH MURNI
# ==========================================

# Matikan tema bawaan grml jika masih menggunakannya
prompt off 2>/dev/null

# Menghubungkan Zsh dengan ssh-agent yang dikelola systemd
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"

# --- KINERJA & SEKURITAS HISTORY ---
HISTFILE=~/.zsh_history
HISTSIZE=50000        # Kapasitas lebih besar untuk melacak pekerjaan berbulan-bulan
SAVEHIST=50000

setopt EXTENDED_HISTORY       # Menyimpan timestamp kapan perintah dieksekusi
setopt SHARE_HISTORY          # Sinkronisasi riwayat antar tab secara real-time
setopt HIST_IGNORE_ALL_DUPS   # Hapus duplikasi perintah lama jika mengetik yang baru
setopt HIST_IGNORE_SPACE      # PENTING: Perintah yang diawali SPASI tidak akan masuk history (Aman untuk token/API key)
setopt HIST_VERIFY            # Jangan langsung eksekusi perintah hasil pencarian history, biarkan user meninjau dulu
setopt APPEND_HISTORY

# --- PERFORMA TERMINAL ---
# Menghindari lag saat melakukan autocomplete pada folder network/mounted drive
zstyle ':completion:*' accept-exact '*(N)'
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.zsh/cache

# Aktifkan menu seleksi visual menggunakan tombol panah
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# --- ADVANCED COMPLETION SYSTEM ---
autoload -Uz compinit && compinit -u

zstyle ':completion:*' menu select=2
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' # Mencocokkan substring & case-insensitive
zstyle ':completion:*:descriptions' format '%F{green}-- %d --%f'             # Kelompokkan menu dengan deskripsi hijau
zstyle ':completion:*:warnings' format '%F{red} Tidak ada kecocokan untuk: %d%f'

# Pewarnaan pada menu autocomplete menggunakan database LS_COLORS sistem
zstyle ':completion:*:default' list-colors ${(s.:.)LS_COLORS}

# Inisialisasi sistem completion bawaan Zsh
autoload -Uz compinit
compinit -u

